# Docker production 실행용 환경변수 예시
# 실제 값은 `eval/docker_deploy.ps1 init`이 생성하는 docker.env에 저장한다.

EMOTION_CHATBOT_ENV=production
EMOTION_CHATBOT_AUTH_SECRET=replace-with-at-least-32-random-characters
EMOTION_CHATBOT_DEVELOPER_PASSWORD=replace-with-at-least-12-characters
EMOTION_CHATBOT_ROOT_PASSWORD=replace-with-a-different-12-character-password
EMOTION_CHATBOT_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
EMOTION_CHATBOT_TRUST_PROXY_HEADERS=1
EMOTION_CHATBOT_TIMEZONE=Asia/Seoul
HF_HOME=/app/.cache/huggingface
